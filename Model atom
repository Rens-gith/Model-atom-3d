import React, { useEffect, useRef } from "react"; import * as THREE from "three";

export default function Periodic3D() { const mountRef = useRef(null);

useEffect(() => { const scene = new THREE.Scene(); const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000); const renderer = new THREE.WebGLRenderer({ antialias: true });

renderer.setSize(window.innerWidth, window.innerHeight);
mountRef.current.appendChild(renderer.domElement);

// Basic light
const light = new THREE.PointLight(0xffffff, 1);
light.position.set(10, 10, 10);
scene.add(light);

// Simple atom generator
function createAtom(x, y, z, color) {
  const group = new THREE.Group();

  // nucleus
  const nucleusGeometry = new THREE.SphereGeometry(0.5, 32, 32);
  const nucleusMaterial = new THREE.MeshStandardMaterial({ color });
  const nucleus = new THREE.Mesh(nucleusGeometry, nucleusMaterial);
  group.add(nucleus);

  // electron orbit
  const orbitGeometry = new THREE.RingGeometry(1.5, 1.6, 32);
  const orbitMaterial = new THREE.MeshBasicMaterial({ color: 0xffffff, side: THREE.DoubleSide });
  const orbit = new THREE.Mesh(orbitGeometry, orbitMaterial);
  orbit.rotation.x = Math.PI / 2;
  group.add(orbit);

  group.position.set(x, y, z);
  scene.add(group);

  return group;
}

// Example: few atoms arranged like periodic table
const atoms = [];
const colors = [0xff0000, 0x00ff00, 0x0000ff, 0xffff00];

let index = 0;
for (let row = 0; row < 5; row++) {
  for (let col = 0; col < 10; col++) {
    atoms.push(createAtom(col * 3, row * 3, 0, colors[index % colors.length]));
    index++;
  }
}

camera.position.z = 30;

// Animation
const animate = () => {
  requestAnimationFrame(animate);

  atoms.forEach((atom, i) => {
    atom.rotation.y += 0.01;
  });

  renderer.render(scene, camera);
};

animate();

return () => {
  mountRef.current.removeChild(renderer.domElement);
};

}, []);

return <div ref={mountRef} className="w-full h-screen" />; }
